# Environment Variables for StadiumFlow Application
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control!

# Google Cloud Project Configuration
GCP_PROJECT_ID=physicaleventexperience
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# API Keys (for local development)
# In production, these should be stored in GCP Secret Manager
STADIUM_API_KEY=your-api-key-here

# GCP Service Account (for local development)
# Download from GCP Console: IAM & Admin > Service Accounts > Keys
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# Spring Profile (local, dev, prod)
SPRING_PROFILES_ACTIVE=local

# Database Configuration (if using external DB in production)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=stadiumdb
# DB_USER=postgres
# DB_PASSWORD=password
